</span></span><span><span>    </span><span class="token token" style="color: rgb(211, 215, 222);">{</span><span class="token token" style="color: rgb(155, 233, 99);">"id"</span><span class="token token" style="color: rgb(211, 215, 222);">:</span><span> </span><span class="token token" style="color: rgb(94, 237, 237);">5</span><span class="token token" style="color: rgb(211, 215, 222);">,</span><span> </span><span class="token token" style="color: rgb(155, 233, 99);">"query"</span><span class="token token" style="color: rgb(211, 215, 222);">:</span><span> </span><span class="token token" style="color: rgb(155, 233, 99);">"What is the best way to exercise Buddy given his schedule?"</span><span class="token token" style="color: rgb(211, 215, 222);">,</span><span> </span><span class="token token" style="color: rgb(155, 233, 99);">"expect_flagged"</span><span class="token token" style="color: rgb(211, 215, 222);">:</span><span> </span><span class="token token" style="color: rgb(94, 237, 237);">False</span><span class="token token" style="color: rgb(211, 215, 222);">,</span><span> </span><span class="token token" style="color: rgb(155, 233, 99);">"expect_success"</span><span class="token token" style="color: rgb(211, 215, 222);">:</span><span> </span><span class="token token" style="color: rgb(94, 237, 237);">True</span><span class="token token" style="color: rgb(211, 215, 222);">,</span><span> </span><span class="token token" style="color: rgb(155, 233, 99);">"description"</span><span class="token token" style="color: rgb(211, 215, 222);">:</span><span> </span><span class="token token" style="color: rgb(155, 233, 99);">"Valid exercise question"</span><span class="token token" style="color: rgb(211, 215, 222);">}</span><span class="token token" style="color: rgb(211, 215, 222);">,</span><span>
